# 全裕 API 配置
quanyu:
  appid: "YOUR_APP_ID"
  key: "YOUR_APP_KEY"
  base_url: "https://iot.xtrunc.com"
  timeout: 30s
  max_retries: 3

# 设备列表获取
device_api:
  url: "https://api.yunniaotech.com/api/admin/devices/uids"
  refresh_interval: 6h

# MongoDB 配置
mongodb:
  uri: "mongodb://localhost:27017"
  database: "quanyu_battery"
  username: "root"
  password: "YOUR_PASSWORD"

# 回调服务配置
callback:
  listen_addr: ":8888"
  notifyurl_base: "http://YOUR_PUBLIC_URL"

# 订阅配置
subscribe:
  batch_size: 20
  renew_interval: 25m
  sub_data:
    - "info"
    - "alarm"
    - "online"

# 日志配置
log:
  dir: "logs"
  level: "info"
  max_size: 100
  max_backups: 30
  max_age: 30
  api_debug_log: false

# 同步任务配置
sync:
  detail:
    cron: "0 */30 * * * *"
    enabled: true
  history_data:
    cron: "0 */5 * * * *"
    enabled: true
    default_range: 1h
  trace:
    cron: "0 */5 * * * *"
    enabled: true
    default_range: 1h
  event:
    cron: "0 */5 * * * *"
    enabled: true
    default_range: 1h
  charge_data:
    cron: "0 */10 * * * *"
    enabled: true
    default_range: 2h
